# Copie para .env.local e preencha para testar localmente com vercel dev
# Dashboard Pagar.me: Configurações > Chaves

PAGAR_ME_SECRET_KEY=sk_test_xxxx
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Para backup do banco: Supabase Dashboard > Connect > Direct connection
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Amazon SES — e-mails transacionais (https://console.aws.amazon.com/ses)
AWS_ACCESS_KEY_ID=SEU_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=SEU_SECRET_KEY
AWS_REGION=eu-north-1

# Remetente padrão — apenas @varvos.com (no-reply, support, billing)
EMAIL_FROM=no-reply@varvos.com

# URL base do site (para links de reset de senha)
SITE_URL=https://www.varvos.com

# Painel admin — senha de acesso (obrigatório para /admin)
ADMIN_PASSWORD=sua-senha-segura-admin

# KIE AI — Imitar Movimento (upload, create-task, record-info)
KIE_API_KEY=sua-kie-api-key

# Cloudflare R2 — motion-refs (Imitar Movimento). Dashboard R2 > API Tokens
R2_ACCESS_KEY_ID=seu-access-key-id
R2_SECRET_ACCESS_KEY=sua-secret-access-key
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=nome-do-bucket
R2_PUBLIC_URL=https://pub-xxx.r2.dev
